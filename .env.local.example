# Database Configuration
DATABASE_URL="postgresql://github_gg_user:github_gg_password@localhost:5432/github_gg"

# Better Auth Configuration
BETTER_AUTH_SECRET="your-super-secret-key-change-this-in-production-make-it-long-and-random"

# GitHub OAuth Configuration
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cloudflare Configuration (optional)
# CLOUDFLARE_ACCOUNT_ID="your-cloudflare-account-id"
# CLOUDFLARE_WORKER_NAME="your-worker-name"
# CLOUDFLARE_WORKER_URL="https://your-worker.workers.dev"

# Optional: GitHub API Key for unauthenticated requests
# GITHUB_PUBLIC_API_KEY=""

# Optional: Google Gemini API Key for AI analysis
# GEMINI_API_KEY=""

# GitHub App Configuration (optional)
# GITHUB_APP_ID="your-app-id"
# GITHUB_APP_PRIVATE_KEY_PATH="./your-private-key.pem"
# WEBHOOK_URL="https://your-webhook-url.com/api/webhooks/github"

