# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/github_gg"

# Better Auth Configuration
BETTER_AUTH_SECRET="your-32-character-secret-key-here"

# GitHub OAuth Configuration (for Better Auth)
GITHUB_CLIENT_ID="your-github-oauth-client-id"
GITHUB_CLIENT_SECRET="your-github-oauth-client-secret"

# GitHub App Configuration
GITHUB_APP_ID="your-github-app-id"
GITHUB_APP_NAME="your-github-app-name"
NEXT_PUBLIC_GITHUB_APP_NAME="your-github-app-name"
NEXT_PUBLIC_GITHUB_APP_ID="your-github-app-id"
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nyour-private-key-content\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET="your-webhook-secret"

# Public Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3001"
GITHUB_PUBLIC_API_KEY="your-public-api-key-for-anonymous-access"

# AI Configuration
GEMINI_API_KEY="your-gemini-api-key"

# Analytics (Optional - comment out if not using)
# NEXT_PUBLIC_POSTHOG_KEY="your-posthog-key"
# NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# Cloudflare Configuration (for webhook worker)
CLOUDFLARE_ACCOUNT_ID="your-cloudflare-account-id"
CLOUDFLARE_WORKER_NAME="webhook-gateway"
CLOUDFLARE_WORKER_URL="https://webhook-gateway.your-domain.workers.dev"
