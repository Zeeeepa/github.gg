# GitHub.gg Environment Configuration Template
# Copy this file to .env.local and fill in your actual values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL="postgresql://github_gg_user:github_gg_password@localhost:5432/github_gg"

# =============================================================================
# GITHUB OAUTH CONFIGURATION
# =============================================================================
# GitHub OAuth App credentials (for user authentication)
# Get these from: https://github.com/settings/developers
GITHUB_CLIENT_ID="Iv23li9PqHMExi84gaq1"
GITHUB_CLIENT_SECRET="d1fbd80a53d530773b3361f23efab3732c436a7b"

# =============================================================================
# GITHUB APP CONFIGURATION
# =============================================================================
# GitHub App credentials (for enhanced repository access)
# Get these from: https://github.com/settings/apps/your-app-name
GITHUB_APP_ID="1484403"
GITHUB_APP_NAME="zeeeepa"
NEXT_PUBLIC_GITHUB_APP_NAME="zeeeepa"
NEXT_PUBLIC_GITHUB_APP_ID="1484403"

# GitHub App Private Key (from downloaded .pem file)
# Replace newlines with \n in the actual key
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT_HERE\n-----END RSA PRIVATE KEY-----"

# Webhook secret for validating GitHub webhook signatures
# Generate a secure random string
GITHUB_WEBHOOK_SECRET="your_secure_webhook_secret_here"

# =============================================================================
# GITHUB API CONFIGURATION
# =============================================================================
# GitHub Personal Access Token for API access
# Create at: https://github.com/settings/tokens
# Scopes needed: repo, read:user, read:org
GITHUB_PUBLIC_API_KEY="your_github_personal_access_token_here"

# =============================================================================
# AI ANALYSIS CONFIGURATION
# =============================================================================
# Google Gemini API Key for AI-powered code analysis
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# =============================================================================
# AUTHENTICATION CONFIGURATION
# =============================================================================
# Secret key for Better Auth (session management)
# Generate a secure random string (32+ characters)
BETTER_AUTH_SECRET="your_random_secret_key_here"

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# Environment mode
NODE_ENV="development"

# Application URL (update for production)
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# =============================================================================
# ANALYTICS CONFIGURATION (OPTIONAL)
# =============================================================================
# PostHog analytics (optional)
# Get from: https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY="your_posthog_project_key_here"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# =============================================================================
# CLOUDFLARE CONFIGURATION
# =============================================================================
# Cloudflare Worker configuration (for webhook gateway)
CLOUDFLARE_ACCOUNT_ID="2b2a1d3effa7f7fe4fe2a8c4e48681e3"
CLOUDFLARE_WORKER_NAME="webhook-gateway"
CLOUDFLARE_WORKER_URL="https://webhook-gateway.pixeliumperfecto.workers.dev"

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================
# Enable debug logging (optional)
# DEBUG="github-gg:*"

# Disable telemetry (optional)
# NEXT_TELEMETRY_DISABLED=1

# =============================================================================
# CONFIGURATION NOTES
# =============================================================================
# 
# 1. GITHUB_PRIVATE_KEY: 
#    - Copy the entire content of your .pem file
#    - Replace actual newlines with \n
#    - Keep the BEGIN/END lines
#
# 2. GITHUB_WEBHOOK_SECRET:
#    - Use the same secret in your GitHub App webhook configuration
#    - Generate with: openssl rand -base64 32
#
# 3. BETTER_AUTH_SECRET:
#    - Generate with: openssl rand -base64 32
#    - Keep this secret and don't share it
#
# 4. DATABASE_URL:
#    - For local development, use the default PostgreSQL container
#    - For production, use your hosted database connection string
#
# 5. NEXT_PUBLIC_* variables:
#    - These are exposed to the client-side code
#    - Don't put sensitive information in NEXT_PUBLIC_* variables
#
# 6. GitHub App Setup:
#    - Homepage URL: http://localhost:3001 (or your domain)
#    - Callback URL: http://localhost:3001/api/auth/callback/github
#    - Webhook URL: https://webhook-gateway.pixeliumperfecto.workers.dev/api/webhooks/github
#
# 7. Required GitHub App Permissions:
#    - Repository: Contents (Read), Metadata (Read), Pull requests (Write)
#    - Account: Email addresses (Read)
#
# 8. Required GitHub App Events:
#    - Installation, Installation repositories, Push, Pull request
#

